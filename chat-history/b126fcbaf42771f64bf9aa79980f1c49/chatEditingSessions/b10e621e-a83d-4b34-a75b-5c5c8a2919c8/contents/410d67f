["{\"transientOutputs\":false,\"transientCellMetadata\":{\"breakpointMargin\":true,\"id\":false,\"metadata\":false,\"attachments\":false},\"transientDocumentMetadata\":{\"cells\":true,\"indentAmount\":true},\"cellContentMetadata\":{\"attachments\":true}}","{\"cells\":[{\"cellKind\":1,\"language\":\"markdown\",\"metadata\":{\"metadata\":{},\"id\":\"f6df0acc\"},\"outputs\":[],\"source\":\"# PXIe-4080 Gain Error Analysis\\n\\nThis notebook parses TDMS files and plots gain error for the **10V** and **300V** ranges of the National Instruments PXIe-4080 across all DUTs, alongside chamber temperature and humidity.\\n\\nRun the cells top-to-bottom. Edit the configuration cell to point at your data and tweak parameters inline.\",\"internalMetadata\":{\"internalId\":\"653763b4\"}},{\"cellKind\":1,\"language\":\"markdown\",\"metadata\":{\"metadata\":{},\"id\":\"5bf692a6\"},\"outputs\":[],\"source\":\"## 1. Imports\",\"internalMetadata\":{\"internalId\":\"338fd1fc\"}},{\"cellKind\":2,\"language\":\"python\",\"metadata\":{\"execution_count\":1,\"id\":\"33dac114\",\"metadata\":{}},\"outputs\":[],\"source\":\"# Use the interactive (ipympl) backend so plots support zoom, pan, and scroll\\n# inside the notebook. Requires the 'ipympl' package. Switch back to\\n# '%matplotlib inline' for static images.\\n%matplotlib widget\\n\\nimport os\\nimport re\\nfrom datetime import datetime\\n\\nfrom nptdms import TdmsFile\\nimport pandas as pd\\nimport numpy as np\\nfrom sklearn.linear_model import LinearRegression\\nimport matplotlib.pyplot as plt\\nimport plotly.graph_objects as go\\n\",\"internalMetadata\":{\"executionId\":\"3d794c60-d36b-41e2-9867-7f305b3997b3\",\"runStartTime\":1781556967704,\"runEndTime\":1781556970891,\"lastRunSuccess\":true,\"executionOrder\":1,\"runStartTimeAdjustment\":0,\"internalId\":\"3cd75b6a\"}},{\"cellKind\":1,\"language\":\"markdown\",\"metadata\":{\"metadata\":{},\"id\":\"6406e4ad\"},\"outputs\":[],\"source\":\"## 2. Helper functions\",\"internalMetadata\":{\"internalId\":\"88087714\"}},{\"cellKind\":2,\"language\":\"python\",\"metadata\":{\"execution_count\":2,\"id\":\"ac171ad3\",\"metadata\":{}},\"outputs\":[],\"source\":\"def compute_gain_error_ppm(test_points, dut_meas):\\n    # Gain error in ppm comes from slope deviation from unity.\\n    X = np.asarray(test_points).reshape(-1, 1)\\n    y = np.asarray(dut_meas)\\n    reg = LinearRegression().fit(X, y)\\n    slope = reg.coef_[0]\\n    return (slope - 1) * 1_000_000\\n\\n\\ndef serial_sort_key(serial):\\n    normalized = str(serial).strip()\\n    if normalized.lower().startswith('0x'):\\n        normalized = normalized[2:]\\n    try:\\n        return (0, int(normalized, 16), str(serial))\\n    except ValueError:\\n        # Fallback keeps stable lexical ordering for unexpected serial formats.\\n        return (1, str(serial))\\n\\n\\ndef get_first_available_channel(group, channel_names):\\n    for channel_name in channel_names:\\n        if channel_name in group:\\n            return group[channel_name][:]\\n    joined = \\\", \\\".join(channel_names)\\n    raise KeyError(f\\\"No channel found from candidates: {joined}\\\")\\n\\n\\ndef parse_filename(filename):\\n    name = filename[:-5].strip()\\n    # Normalize extra spaces and AM/PM spacing\\n    name = re.sub(r'\\\\s+', ' ', name)\\n    name = re.sub(r'\\\\s+(AM|PM)$', r'_\\\\1', name)\\n    name = name.replace('RH_Set_ ', 'RH_Set_')\\n\\n    pattern = re.compile(\\n        r'^(?P<serial>[^_]+)_Temp_Set_(?P<temp>[^_]+)_RH_Set_(?P<rh>\\\\d+)_(?P<month>\\\\d+)_(?P<day>\\\\d+)_(?P<year>\\\\d+)_(?P<hour>\\\\d+)_(?P<minute>\\\\d+)_(?P<second>\\\\d+)_(?P<am_pm>AM|PM)$'\\n    )\\n    match = pattern.match(name)\\n    if not match:\\n        raise ValueError(f\\\"Unable to parse filename: {filename}\\\")\\n\\n    serial = match.group('serial')\\n    temp_set = match.group('temp')\\n    rh_set = match.group('rh')\\n    month = int(match.group('month'))\\n    day = int(match.group('day'))\\n    year = int(match.group('year'))\\n    hour = int(match.group('hour'))\\n    minute = int(match.group('minute'))\\n    second = int(match.group('second'))\\n    am_pm = match.group('am_pm')\\n\\n    dt = datetime(year, month, day, hour, minute, second)\\n    if am_pm == 'PM' and hour != 12:\\n        dt = dt.replace(hour=hour + 12)\\n    elif am_pm == 'AM' and hour == 12:\\n        dt = dt.replace(hour=0)\\n    return serial, temp_set, rh_set, dt\",\"internalMetadata\":{\"executionId\":\"88358cd4-765f-4d92-b5ed-28090ded224b\",\"runStartTime\":1781556970907,\"runEndTime\":1781556970911,\"lastRunSuccess\":true,\"executionOrder\":2,\"runStartTimeAdjustment\":0,\"internalId\":\"4730dcee\"}},{\"cellKind\":1,\"language\":\"markdown\",\"metadata\":{\"metadata\":{},\"id\":\"3d5198cd\"},\"outputs\":[],\"source\":\"## 3. Configuration\\n\\nSet the root path that contains one subfolder per DUT serial number. Adjust `GAIN_ERROR_LIMIT_PPM` to change the outlier cutoff.\",\"internalMetadata\":{\"internalId\":\"bf8d477d\"}},{\"cellKind\":2,\"language\":\"python\",\"metadata\":{\"execution_count\":3,\"id\":\"40c549e6\",\"metadata\":{}},\"outputs\":[],\"source\":\"ROOT_PATH = r\\\"C:\\\\temp\\\\EnvironmentalTesting\\\\Round2Data\\\"\\nGAIN_ERROR_LIMIT_PPM = 100\\nOUTPUT_IMAGE = \\\"gain_error_plot.png\\\"\\nOUTPUT_HTML = \\\"gain_error_plot.html\\\"\\n\\n# PNG resolution. matplotlib has no hard DPI cap; the practical ceiling is the\\n# Agg renderer's 2**16 (65536) pixel-per-axis limit. With a 14 in wide figure\\n# that works out to ~4680 DPI before it errors. 600-1200 is plenty for print;\\n# higher just makes a bigger file. For unlimited resolution, save SVG/PDF.\\nOUTPUT_DPI = 600\\n\",\"internalMetadata\":{\"executionId\":\"73310832-9810-4132-ad3a-87684f4fbe90\",\"runStartTime\":1781556970917,\"runEndTime\":1781556970921,\"lastRunSuccess\":true,\"executionOrder\":3,\"runStartTimeAdjustment\":0,\"internalId\":\"52789396\"}},{\"cellKind\":1,\"language\":\"markdown\",\"metadata\":{\"metadata\":{},\"id\":\"67f7ce32\"},\"outputs\":[],\"source\":\"## 4. Load TDMS data\\n\\nWalks each serial folder, computes gain error for the 10V and 300V ranges, and drops any point outside +/- `GAIN_ERROR_LIMIT_PPM`.\",\"internalMetadata\":{\"internalId\":\"2576547a\"}},{\"cellKind\":2,\"language\":\"python\",\"metadata\":{\"execution_count\":4,\"id\":\"aef7ae73\",\"metadata\":{}},\"outputs\":[{\"outputId\":\"55f59dbe-c311-4330-8320-bda50010a65e\",\"metadata\":{\"outputType\":\"stream\"},\"outputs\":[{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"\"},\"mime\":\"application/vnd.code.notebook.stdout\"}]},{\"outputId\":\"50ffc83d-243f-4592-a6c8-3bb0363ffce5\",\"metadata\":{\"outputType\":\"execute_result\",\"executionCount\":4,\"metadata\":{}},\"outputs\":[{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"\"},\"mime\":\"text/html\"},{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"\"},\"mime\":\"text/plain\"}]}],\"source\":\"data = []\\n\\nif not os.path.exists(ROOT_PATH):\\n    raise FileNotFoundError(f\\\"Path '{ROOT_PATH}' does not exist. Please verify the directory path.\\\")\\n\\n# Collect every .tdms file up front so we can report progress while loading.\\ntdms_files = []\\nfor subdir in os.listdir(ROOT_PATH):\\n    serial_path = os.path.join(ROOT_PATH, subdir)\\n    if not os.path.isdir(serial_path):\\n        continue\\n    for file in os.listdir(serial_path):\\n        if file.endswith('.tdms'):\\n            tdms_files.append((serial_path, file))\\n\\ntotal_files = len(tdms_files)\\nprint(f\\\"Found {total_files} TDMS file(s) to process.\\\")\\n\\nfor idx, (serial_path, file) in enumerate(tdms_files, start=1):\\n    print(f\\\"\\\\r[{idx}/{total_files}] Loading {file[:60]}\\\", end='', flush=True)\\n    filepath = os.path.join(serial_path, file)\\n    try:\\n        parsed_serial, temp_set, rh_set, timestamp = parse_filename(file)\\n        tdms_file = TdmsFile.read(filepath)\\n        group = tdms_file.groups()[0]\\n        chamber_temp = get_first_available_channel(\\n            group,\\n            ['Chamber Temperature 300V', 'Chamber Temperature']\\n        )\\n        chamber_rh = get_first_available_channel(\\n            group,\\n            ['Chamber RH% 300V', 'Chamber RH%']\\n        )\\n        avg_temp = np.mean(chamber_temp)\\n        avg_rh = np.mean(chamber_rh)\\n\\n        ranges = [\\n            ('10V', ['Test Points 10V'], ['DUT Measurements 10V']),\\n            ('300V', ['Test Points 300V', 'Test Points'], ['DUT Measurements 300V', 'DUT Measurements'])\\n        ]\\n\\n        for range_name, test_candidates, dut_candidates in ranges:\\n            test_col = next((col for col in test_candidates if col in group), None)\\n            dut_col = next((col for col in dut_candidates if col in group), None)\\n            if test_col is None or dut_col is None:\\n                continue\\n\\n            test_points = group[test_col][:]\\n            dut_meas = group[dut_col][:]\\n            gain_error = compute_gain_error_ppm(test_points, dut_meas)\\n\\n            # Omit outliers outside the valid gain error window.\\n            if abs(gain_error) > GAIN_ERROR_LIMIT_PPM:\\n                print(\\n                    f\\\"\\\\nOmitting {range_name} point from {file}: \\\"\\n                    f\\\"gain error {gain_error:.2f} ppm exceeds +/-{GAIN_ERROR_LIMIT_PPM} ppm\\\"\\n                )\\n                continue\\n\\n            data.append({\\n                'timestamp': timestamp,\\n                'serial': parsed_serial,\\n                'range': range_name,\\n                'gain_error': gain_error,\\n                'avg_temp': avg_temp,\\n                'avg_rh': avg_rh\\n            })\\n    except Exception as e:\\n        print(f\\\"\\\\nError processing {filepath}: {e}\\\")\\n\\nprint(f\\\"\\\\nDone. Loaded {len(data)} data point(s) from {total_files} file(s).\\\")\\n\\ndf = pd.DataFrame(data)\\nif df.empty:\\n    print(\\\"No data found.\\\")\\nelse:\\n    df = df.sort_values(['serial', 'timestamp'])\\ndf.head()\",\"internalMetadata\":{\"executionId\":\"5c11bbb9-34b2-46c6-88c5-0918bd858141\",\"runStartTime\":1781556970941,\"runEndTime\":1781557241984,\"lastRunSuccess\":true,\"executionOrder\":4,\"renderDuration\":{\"vscode.builtin-renderer\":142},\"runStartTimeAdjustment\":0,\"internalId\":\"1f05b7fa\"}},{\"cellKind\":1,\"language\":\"markdown\",\"metadata\":{\"metadata\":{},\"id\":\"9b1aa660\"},\"outputs\":[],\"source\":\"## 5. Plot gain error and chamber conditions\\n\\nEach serial gets a unique color shared by its 10V (dashed, square markers) and 300V (solid, round markers) traces.\",\"internalMetadata\":{\"internalId\":\"934f6033\"}},{\"cellKind\":2,\"language\":\"python\",\"metadata\":{\"execution_count\":5,\"id\":\"e02ff5f5\",\"metadata\":{}},\"outputs\":[{\"outputId\":\"0b6253df-274d-4890-a7cb-0de504567069\",\"metadata\":{\"outputType\":\"display_data\",\"transient\":{},\"metadata\":{},\"__displayOpenPlotIcon\":true},\"outputs\":[{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"eyJ2ZXJzaW9uX21ham9yIjoyLCJ2ZXJzaW9uX21pbm9yIjowLCJtb2RlbF9pZCI6ImI4ODY0ZjM2YTc3OTRlOTY5MGRkZjgzODg4Y2YzOTkwIn0=\"},\"mime\":\"application/vnd.jupyter.widget-view+json\"},{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"\"},\"mime\":\"text/html\"},{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"\"},\"mime\":\"image/png\"},{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"Q2FudmFzKHRvb2xiYXI9VG9vbGJhcih0b29saXRlbXM9WygnSG9tZScsICdSZXNldCBvcmlnaW5hbCB2aWV3JywgJ2hvbWUnLCAnaG9tZScpLCAoJ0JhY2snLCAnQmFjayB0byBwcmV2aW91cyDigKY=\"},\"mime\":\"text/plain\"}]}],\"source\":\"if df.empty:\\n    raise ValueError(\\\"No data to plot. Run the data-loading cell first.\\\")\\n\\nfig, ax1 = plt.subplots(figsize=(14, 8))\\n\\n# Gain error for each serial in ascending order.\\nserials = sorted(df['serial'].unique(), key=serial_sort_key)\\n\\n# Assign a unique color per serial so 10V and 300V share the serial's color.\\ncolormap = plt.get_cmap('tab20' if len(serials) > 10 else 'tab10')\\nserial_colors = {ser: colormap(idx % colormap.N) for idx, ser in enumerate(serials)}\\n\\nfor ser in serials:\\n    ser_df = df[df['serial'] == ser]\\n    for range_name, linestyle, marker in [('10V', '--', 's'), ('300V', '-', 'o')]:\\n        range_df = ser_df[ser_df['range'] == range_name]\\n        if range_df.empty:\\n            continue\\n        ax1.plot(\\n            range_df['timestamp'],\\n            range_df['gain_error'],\\n            label=f'{ser} {range_name}',\\n            color=serial_colors[ser],\\n            linestyle=linestyle,\\n            marker=marker\\n        )\\n\\nax1.set_xlabel('Time')\\nax1.set_ylabel('Gain Error - PPM')\\nax1.legend(loc='upper left')\\n\\n# Secondary y-axis for avg_temp (deduplicated by timestamp).\\nenv_df = df.sort_values('timestamp').drop_duplicates(subset=['timestamp'])\\n\\nax2 = ax1.twinx()\\nax2.plot(env_df['timestamp'], env_df['avg_temp'], 'r-', label='Avg Chamber Temp', linewidth=2)\\nax2.set_ylabel('Avg Chamber Temperature (°C)', color='r')\\nax2.tick_params(axis='y', labelcolor='r')\\n\\nax3 = ax1.twinx()\\nax3.spines['right'].set_position(('outward', 60))\\nax3.plot(env_df['timestamp'], env_df['avg_rh'], 'g-', label='Avg Chamber RH%', linewidth=2)\\nax3.set_ylabel('Avg Chamber RH (%)', color='g')\\nax3.tick_params(axis='y', labelcolor='g')\\n\\nplt.title('PXIe-4080 Gain Error (10V and 300V) and Chamber Conditions Over Time')\\nfig.tight_layout()\\nplt.savefig(OUTPUT_IMAGE, dpi=OUTPUT_DPI)\\nplt.show()\\n\",\"internalMetadata\":{\"executionId\":\"1cf8b80e-0da7-4555-b2b6-a1713216d678\",\"runStartTime\":1781557241997,\"runEndTime\":1781557245239,\"lastRunSuccess\":true,\"executionOrder\":5,\"renderDuration\":{\"jupyter-ipywidget-renderer\":39},\"runStartTimeAdjustment\":0,\"internalId\":\"006f61e7\"}},{\"cellKind\":1,\"language\":\"markdown\",\"metadata\":{\"metadata\":{},\"id\":\"2096afc6\"},\"outputs\":[],\"source\":\"## 6. Interactive HTML export\\n\\nBuilds a Plotly version of the same chart and writes a self-contained `.html`\\nfile. Unlike the ipympl widget above, this HTML keeps its zoom/pan/hover after\\nthe kernel stops, so it can be opened in any browser without rerunning the\\nnotebook. Click legend entries to toggle traces; double-click to isolate one.\\n\",\"internalMetadata\":{\"internalId\":\"6e2d04df\"}},{\"cellKind\":2,\"language\":\"python\",\"metadata\":{\"execution_count\":null,\"id\":\"ab57a371\",\"metadata\":{}},\"outputs\":[{\"outputId\":\"9c00cbb7-2109-4e70-938c-66f7a897a34b\",\"metadata\":{\"outputType\":\"error\",\"originalError\":{\"output_type\":\"error\",\"ename\":\"SyntaxError\",\"evalue\":\"invalid syntax. Perhaps you forgot a comma? (550530993.py, line 71)\",\"traceback\":[\"  \\u001b[36mCell\\u001b[39m\\u001b[36m \\u001b[39m\\u001b[32mIn[8]\\u001b[39m\\u001b[32m, line 71\\u001b[39m\\n\\u001b[31m    \\u001b[39m\\u001b[31mfull_html=True,ifig.show()\\u001b[39m\\n                   ^\\n\\u001b[31mSyntaxError\\u001b[39m\\u001b[31m:\\u001b[39m invalid syntax. Perhaps you forgot a comma?\\n\"]}},\"outputs\":[{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"\"},\"mime\":\"application/vnd.code.notebook.error\"}]}],\"source\":\"if df.empty:\\n    raise ValueError(\\\"No data to plot. Run the data-loading cell first.\\\")\\n\\n# Reuse the same ordering, per-serial colors, and dedup env data as the\\n# matplotlib figure so the two views match.\\nserials = sorted(df['serial'].unique(), key=serial_sort_key)\\ncolormap = plt.get_cmap('tab20' if len(serials) > 10 else 'tab10')\\n\\n\\ndef _to_rgba(rgba):\\n    r, g, b, a = rgba\\n    return f'rgba({int(r * 255)},{int(g * 255)},{int(b * 255)},{a:.3f})'\\n\\n\\nserial_colors = {ser: _to_rgba(colormap(idx % colormap.N)) for idx, ser in enumerate(serials)}\\nenv_df = df.sort_values('timestamp').drop_duplicates(subset=['timestamp'])\\n\\nifig = go.Figure()\\n\\n# Gain error traces (left y-axis): 10V dashed/square, 300V solid/circle.\\nfor ser in serials:\\n    ser_df = df[df['serial'] == ser]\\n    for range_name, dash, symbol in [('10V', 'dash', 'square'), ('300V', 'solid', 'circle')]:\\n        range_df = ser_df[ser_df['range'] == range_name]\\n        if range_df.empty:\\n            continue\\n        ifig.add_trace(go.Scatter(\\n            x=range_df['timestamp'],\\n            y=range_df['gain_error'],\\n            mode='lines+markers',\\n            name=f'{ser} {range_name}',\\n            line=dict(color=serial_colors[ser], dash=dash),\\n            marker=dict(symbol=symbol, color=serial_colors[ser]),\\n            yaxis='y1',\\n            hovertemplate=f'{ser} {range_name}<br>%{{x}}<br>%{{y:.2f}} ppm<extra></extra>'\\n        ))\\n\\n# Chamber temperature (second y-axis) and RH% (third y-axis).\\nifig.add_trace(go.Scatter(\\n    x=env_df['timestamp'], y=env_df['avg_temp'], mode='lines',\\n    name='Avg Chamber Temp', line=dict(color='red', width=2), yaxis='y2',\\n    hovertemplate='Temp<br>%{x}<br>%{y:.2f} °C<extra></extra>'\\n))\\nifig.add_trace(go.Scatter(\\n    x=env_df['timestamp'], y=env_df['avg_rh'], mode='lines',\\n    name='Avg Chamber RH%', line=dict(color='green', width=2), yaxis='y3',\\n    hovertemplate='RH<br>%{x}<br>%{y:.2f} %<extra></extra>'\\n))\\n\\nifig.update_layout(\\n    title='PXIe-4080 Gain Error (10V and 300V) and Chamber Conditions Over Time',\\n    autosize=True,\\n    hovermode='x unified',\\n    xaxis=dict(title='Time', domain=[0.0, 0.88]),\\n    yaxis=dict(title='Gain Error - PPM'),\\n    yaxis2=dict(title=dict(text='Avg Chamber Temperature (°C)', font=dict(color='red')),\\n                tickfont=dict(color='red'), overlaying='y', side='right'),\\n    yaxis3=dict(title=dict(text='Avg Chamber RH (%)', font=dict(color='green')),\\n                tickfont=dict(col