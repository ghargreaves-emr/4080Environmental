:\"4f236dea\",\"metadata\":{}},\"outputs\":[],\"source\":\"## 7. Per-serial interactive HTML exports\\n\\nWrites one self-contained `.html` file per serial number into the\\n`OUTPUT_HTML_DIR` folder. Each file plots that serial's **10V** and **300V**\\ngain error together with the chamber temperature and humidity recorded during\\nthat serial's tests. Like the combined export, each file keeps its\\nzoom/pan/hover after the kernel stops.\\n\",\"internalMetadata\":{\"internalId\":\"90a74de3\"}},{\"cellKind\":2,\"language\":\"python\",\"metadata\":{\"execution_count\":null,\"id\":\"81f70631\",\"metadata\":{}},\"outputs\":[{\"outputId\":\"174720aa-b07b-470c-a1fa-9b2356a255c8\",\"metadata\":{\"outputType\":\"stream\"},\"outputs\":[{\"data\":{\"type\":\"ArrayBuffer-4f56482b-5a03-49ba-8356-210d3b0c1c3d\",\"data\":\"\"},\"mime\":\"application/vnd.code.notebook.stdout\"}]}],\"source\":\"if df.empty:\\n    raise ValueError(\\\"No data to plot. Run the data-loading cell first.\\\")\\n\\n# Folder for the per-serial HTML files.\\nOUTPUT_HTML_DIR = \\\"per_serial_html\\\"\\nos.makedirs(OUTPUT_HTML_DIR, exist_ok=True)\\n\\n# Reuse the same ordering and per-serial colors as the combined views so a\\n# given serial keeps its color across every plot.\\nserials = sorted(df['serial'].unique(), key=serial_sort_key)\\ncolormap = plt.get_cmap('tab20' if len(serials) > 10 else 'tab10')\\nserial_colors = {ser: _to_rgba(colormap(idx % colormap.N)) for idx, ser in enumerate(serials)}\\n\\n\\ndef _safe_filename(serial):\\n    # Keep only filesystem-safe characters so the serial maps to a valid name.\\n    return re.sub(r'[^0-9A-Za-z_.-]', '_', str(serial))\\n\\n\\nwritten = []\\nfor ser in serials:\\n    ser_df = df[df['serial'] == ser].sort_values('timestamp')\\n\\n    sfig = go.Figure()\\n\\n    # Gain error traces (left y-axis): 10V dashed/square, 300V solid/circle.\\n    for range_name, dash, symbol in [('10V', 'dash', 'square'), ('300V', 'solid', 'circle')]:\\n        range_df = ser_df[se